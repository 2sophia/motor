# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Motor defaults — read by MotorConfig at construction time.
# Resolution cascade: explicit MotorConfig(...) param > env var > default.
SOPHIA_MOTOR_MODEL=claude-opus-4-6
SOPHIA_MOTOR_WORKSPACE_ROOT=~/.sophia-motor/runs
SOPHIA_MOTOR_PROXY_HOST=127.0.0.1

# Debug knobs — both default OFF in production. Flip on locally to
# inspect what the motor is doing turn-by-turn.
SOPHIA_MOTOR_CONSOLE_LOG=false
SOPHIA_MOTOR_AUDIT_DUMP=false

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Motor defaults (optional — overridable per Motor instance)
SOPHIA_MOTOR_MODEL=claude-opus-4-6
SOPHIA_MOTOR_WORKSPACE_ROOT=./.runs
SOPHIA_MOTOR_PROXY_HOST=127.0.0.1
SOPHIA_MOTOR_CONSOLE_LOG=true
SOPHIA_MOTOR_AUDIT_DUMP=true

# Pip Publish
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-...